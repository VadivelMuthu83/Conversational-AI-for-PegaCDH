# ════════════════════════════════════════════════════════════════════
#  Copilot Analyst — backend/.env
#
#  SETUP:
#    1. Rename this file from  .env.template  to  .env
#    2. Pick ONE LLM provider below and fill in its key
#    3. Set KNOWLEDGE_PATH to the absolute path of your sample-data
#
#  This file must stay in the  backend\  folder (next to install.py)
# ════════════════════════════════════════════════════════════════════


# ── STEP 1: Choose your LLM provider ─────────────────────────────────────────
# Uncomment ONE block below. Comment out the rest.


# ── Option A: Google Gemini (FREE TIER — recommended for new users) ──────────
# Get key in 1 minute: https://aistudio.google.com → Get API Key
LLM_PROVIDER=gemini
GEMINI_API_KEY=PASTE_YOUR_GEMINI_KEY_HERE
GEMINI_MODEL=gemini-2.0-flash


# ── Option B: OpenAI GPT-4o ──────────────────────────────────────────────────
# Get key: https://platform.openai.com/api-keys
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-paste-your-openai-key-here
# OPENAI_MODEL=gpt-4o


# ── Option C: Azure OpenAI ───────────────────────────────────────────────────
# Get from: Azure Portal → Azure OpenAI Service → Keys and Endpoint
# LLM_PROVIDER=azure
# AZURE_OPENAI_API_KEY=paste-your-azure-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-01


# ── Option D: Anthropic Claude ───────────────────────────────────────────────
# Get key: https://console.anthropic.com → API Keys
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-paste-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514


# ── STEP 2: Set the path to your data files ───────────────────────────────────
# Use the full absolute Windows path (copy from Explorer address bar)
# Example: C:\Users\vadiv\Downloads\SmartAnalysis\SmartAnalysis\sample-data
KNOWLEDGE_PATH=PASTE_FULL_PATH_TO_SAMPLE_DATA_FOLDER_HERE


# ── RAG settings — safe defaults, no need to change ──────────────────────────
RAG_STORE_PATH=./index
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_PROVIDER=local
FILE_SOURCE=local
RAG_ENABLED=true
RETRIEVAL_MODE=hybrid
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K_RETRIEVAL=8
TOP_K_RERANK=4
INDEX_PERSIST=true
STREAMING_ENABLED=true
LOG_LEVEL=INFO

# These are off by default — they make extra LLM calls
QUERY_EXPANSION_ENABLED=false
HYDE_ENABLED=false
RERANKER_ENABLED=false

# ── Optional features — leave as-is unless you use them ──────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=copilot-analyst
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
POLARIS_ENABLED=false
