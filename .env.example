# ════════════════════════════════════════════════════════════
#  Copilot Analyst / SmartAnalysis — .env
#  Copy this file to .env, then set your API key and path.
# ════════════════════════════════════════════════════════════

# ── LLM ──────────────────────────────────────────────────────
# Pick one provider and set its key. Leave the others blank.

LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIzaSy-paste-your-gemini-key-here    ← free tier at aistudio.google.com

# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-paste-your-key-here

# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-paste-your-key-here

# ── Files ─────────────────────────────────────────────────────
FILE_SOURCE=local

# IMPORTANT: Set this to the ABSOLUTE path of your sample-data folder.
# Copy and paste the exact path from Windows Explorer address bar.
#
# Example:
# KNOWLEDGE_PATH=C:\Users\vadiv\Downloads\SmartAnalysis\SmartAnalysis\sample-data
#
KNOWLEDGE_PATH=C:\Users\vadiv\Downloads\SmartAnalysis\SmartAnalysis\sample-data

# ── RAG index ─────────────────────────────────────────────────
# Where the FAISS vector index is saved between restarts.
# Use a path inside the project so it is easy to find and delete.
RAG_STORE_PATH=./index

# ── Embedding model ───────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_PROVIDER=local

# ── RAG settings ──────────────────────────────────────────────
RAG_ENABLED=true
RETRIEVAL_MODE=hybrid
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K_RETRIEVAL=8
TOP_K_RERANK=4
INDEX_PERSIST=true
QUERY_EXPANSION_ENABLED=true
HYDE_ENABLED=false
RERANKER_ENABLED=false
STREAMING_ENABLED=true

# ── LangSmith (optional) ──────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pega-cdh-analyst
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Polaris (optional) ────────────────────────────────────────
POLARIS_ENABLED=false

# ── Performance ───────────────────────────────────────────────
MAX_FILE_SIZE_MB=500
MAX_WORKERS=4
BATCH_EMBED_SIZE=64
LOG_LEVEL=INFO
